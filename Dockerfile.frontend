FROM node:20-alpine AS builder
WORKDIR /app
COPY nexus/frontend/package*.json ./
RUN npm install
COPY nexus/frontend/ .
ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL
RUN npm run build || { cat /root/.npm/_logs/*.log 2>/dev/null; exit 1; }

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nexus/frontend/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
