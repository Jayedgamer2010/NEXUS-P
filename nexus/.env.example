# ================================================================
# NEXUS Dashboard - Environment Configuration
# ================================================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env with real credentials to version control.
# ================================================================

# ---- MySQL / MariaDB Database (REQUIRED) ----
# Database connection settings for the MySQL/MariaDB server.
# In Docker, these map to the mysql service defined in docker-compose.yml.
MARIADB_ROOT_PASSWORD=nexus_root_password
MARIADB_DATABASE=mythicaldash
MARIADB_USER=nexus
MARIADB_PASSWORD=nexus_password

# ---- Redis ----
REDIS_PASSWORD=nexus_redis_password

# ---- Pterodactyl Panel Integration ----
PTERODACTYL_URL=http://your-pterodactyl-url
PTERODACTYL_API_KEY=your-pterodactyl-api-key

# ---- Application ----
APP_URL=localhost
APP_NAME=NEXUS
