{
	"name": "mythicaldash-frontend",
	"version": "0.0.1",
	"private": false,
	"publisher": "MythicalSystems",
	"description": "Frontend for MythicalDash - The next generation server management panel.",
	"author": {
		"name": "NaysKutzu",
		"email": "ghermancassian2008@gmail.com",
		"url": "https://mythical.systems"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/mythicalltd/mythicaldash"
	},
	"bugs": {
		"url": "https://github.com/mythicalltd/mythicaldash/issues"
	},
	"homepage": "https://www.mythical.systems",
	"license": "MIT",
	"type": "module",
	"keywords": [
		"mythicaldash",
		"vue",
		"vite",
		"server",
		"dashboard",
		"panel"
	],
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/nayskutzu"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"scripts": {
		"dev": "vite --host",
		"build": "NODE_OPTIONS=--max_old_space_size=4096 run-p type-check \"build-only {@}\" --",
		"build-win": "run-p type-check \"build-only {@}\" --",
		"build-dev": "NODE_OPTIONS=--max_old_space_size=4096 run-p type-check \"build-only {@}\" -- --mode development",
		"build-analyze": "NODE_OPTIONS=--max_old_space_size=4096 npx vite-bundle-analyzer dist --open false",
		"preview": "vite preview",
		"build-only": "vite build",
		"type-check": "vue-tsc --build --force",
		"lint": "pnpm format && oxlint . --fix",
		"format": "prettier --log-level silent --write src/",
		"clean": "rm -rf dist node_modules .vite",
		"check": "pnpm lint && pnpm type-check"
	},
	"packageManager": "pnpm@10.22.0",
	"dependencies": {
		"@modyfi/vite-plugin-yaml": "^1.1.1",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/vue-table": "^8.21.3",
		"@tsconfig/node22": "^22.0.5",
		"@types/node": "^25.2.3",
		"@vitejs/plugin-vue": "^6.0.4",
		"@vue/tsconfig": "^0.8.1",
		"@vueuse/sound": "^2.1.3",
		"chart.js": "^4.5.1",
		"date-fns": "^4.1.0",
		"lucide-vue-next": "^0.564.0",
		"npm-run-all2": "^8.0.4",
		"oxlint": "^1.47.0",
		"pinia": "^3.0.4",
		"prettier": "^3.8.1",
		"qrcode": "^1.5.4",
		"sweetalert2": "^11.26.18",
		"tailwindcss": "^4.1.18",
		"typescript": "~5.9.3",
		"vite": "npm:rolldown-vite@latest",
		"vite-bundle-analyzer": "^1.3.6",
		"vite-plugin-oxlint": "^1.6.0",
		"vite-plugin-vue-devtools": "^8.0.6",
		"vue": "^3.5.28",
		"vue-i18n": "^11.2.8",
		"vue-qrcode": "^2.2.2",
		"vue-router": "^5.0.2",
		"vue-sweetalert2": "^5.0.11",
		"vue-tsc": "^3.2.4",
		"vue-turnstile": "^1.0.11"
	}
}
