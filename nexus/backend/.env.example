# ================================================================
# NEXUS - MythicalDash Environment Configuration
# ================================================================
# Copy this file to .env and fill in the values.
# DO NOT commit .env with real credentials to version control.
# ================================================================

# ---- Supabase (PostgreSQL via REST API) ----
# Uncomment these and comment out the DATABASE_* lines below
# to use Supabase instead of a traditional MySQL server.

# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-key-or-anon-key

# ---- Traditional MySQL (PDO) ----
# If Supabase is not configured above, these settings are used
# as a fallback for direct MySQL connections.

DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_DATABASE=mythicaldash
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_ENCRYPTION_KEY=

# ---- Redis ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Pterodactyl Panel Integration ----
PTERODACTYL_URL=
PTERODACTYL_API_KEY=

# ---- Application ----
APP_ENV=production
APP_URL=
APP_NAME=NEXUS

# ---- Logging ----
LOG_PATH=../storage/logs/
LOG_LEVEL=debug

# ---- Misc ----
MYTHICAL_VERSION=6.8.1-rc
DEMO=false
FIREWALL_ENABLED=true
FIREWALL_RATE_LIMIT=100
FIREWALL_BLOCK_VPN=false
