# ================================================================
# NEXUS - Backend Environment Configuration
# ================================================================
# Copy this file to .env and fill in the values.
# DO NOT commit .env with real credentials to version control.
# ================================================================

# ---- MySQL / MariaDB Database (REQUIRED) ----
# Local or remote MySQL/MariaDB server.
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_DATABASE=mythicaldash
DATABASE_USER=root
DATABASE_PASSWORD=

# Database encryption (xchacha20 for field-level encryption)
# Leave empty to auto-generate, or provide your own 32-byte base64 key
DATABASE_ENCRYPTION_KEY=

# ---- Redis ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Pterodactyl Panel Integration ----
PTERODACTYL_URL=
PTERODACTYL_API_KEY=

# ---- Application ----
APP_ENV=production
APP_URL=
APP_NAME=NEXUS

# ---- Logging ----
LOG_PATH=../storage/logs/
LOG_LEVEL=debug

# ---- Misc ----
MYTHICAL_VERSION=6.8.1-rc
DEMO=false
FIREWALL_ENABLED=true
FIREWALL_RATE_LIMIT=100
FIREWALL_BLOCK_VPN=false
