# ================================================================
# NEXUS - Backend Environment Configuration
# ================================================================
# Copy this file to .env and fill in the values.
# DO NOT commit .env with real credentials to version control.
# ================================================================

# ---- Supabase (REQUIRED - PostgreSQL + Auth via REST API) ----
# Create a project at https://supabase.com and get these from
# Settings > API > Project URL + anon/public + service_role keys.
#   - SUPABASE_URL       = your project URL  (https://xxx.supabase.co)
#   - SUPABASE_SERVICE_KEY = your service_role key (NOT the anon key)
# The anon key is used by the frontend (VITE_SUPABASE_ANON_KEY).
# The service_role key is used by the backend (bypasses RLS).
# ================================================================

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ---- Redis ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Legacy MySQL Fallback ----
# ONLY used if SUPABASE_URL and SUPABASE_SERVICE_KEY are NOT set.
# For new installations, ALWAYS use Supabase.
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=3306
# DATABASE_DATABASE=mythicaldash
# DATABASE_USER=root
# DATABASE_PASSWORD=
# DATABASE_ENCRYPTION_KEY=

# ---- Pterodactyl Panel Integration ----
PTERODACTYL_URL=
PTERODACTYL_API_KEY=

# ---- Application ----
APP_ENV=production
APP_URL=
APP_NAME=NEXUS

# ---- Logging ----
LOG_PATH=../storage/logs/
LOG_LEVEL=debug

# ---- Misc ----
MYTHICAL_VERSION=6.8.1-rc
DEMO=false
FIREWALL_ENABLED=true
FIREWALL_RATE_LIMIT=100
FIREWALL_BLOCK_VPN=false
